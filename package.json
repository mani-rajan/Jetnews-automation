{
  "name": "mobile-automation",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "e2e": "wdio run config/wdio.android.conf.ts",
    "bdd:android": "node scripts/run-android-and-report.js",
    "bdd:android:run": "wdio run config/wdio.android.conf.ts",
    "bdd:android:parallel": "cross-env MAX_INSTANCES=2 wdio run config/wdio.android.conf.ts",
    "bdd:android:multidevice": "cross-env MULTI_DEVICE=true MAX_INSTANCES=2 REQUIRE_ALL_DEVICES=true USE_INSTALLED_APP=true wdio run config/wdio.android.conf.ts",
    "bdd:android:multidevice:oneshot": "cross-env USE_INSTALLED_APP=true powershell -NoProfile -ExecutionPolicy Bypass -File scripts/run-android-multidevice.ps1",
    "bdd:android:two-emulators": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/run-android-two-emulators.ps1",
    "bdd:ios": "wdio run config/wdio.ios.conf.ts",
    "bdd:ios:multidevice": "cross-env MULTI_DEVICE=true MAX_INSTANCES=2 wdio run config/wdio.ios.conf.ts",
    "report:cucumber": "node scripts/generate-cucumber-report.js",
    "report:allure": "allure generate allure-results --clean -o reports/allure-html",
    "report:allure:open": "allure open reports/allure-html",
    "bdd:android:report": "npm run bdd:android:run && npm run report:cucumber",
    "bdd:android:parallel:report": "npm run bdd:android:parallel && npm run report:cucumber",
    "bdd:android:report:allure": "npm run bdd:android:run && npm run report:allure",
    "bdd:android:two-emulators:report": "node scripts/run-two-emulators-and-report.js",
    "bdd:android:multidevice:report": "npm run bdd:android:multidevice && npm run report:cucumber"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@appium/images-plugin": "^4.1.1",
    "@appium/relaxed-caps-plugin": "^2.1.0",
    "@types/chai": "^5.2.3",
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.5.0",
    "@wdio/allure-reporter": "^9.27.0",
    "@wdio/appium-service": "^9.27.0",
    "@wdio/cli": "^9.27.0",
    "@wdio/cucumber-framework": "^9.27.0",
    "@wdio/globals": "^9.27.0",
    "@wdio/local-runner": "^9.27.0",
    "@wdio/mocha-framework": "^9.27.0",
    "@wdio/spec-reporter": "^9.27.0",
    "@wdio/types": "^9.27.0",
    "allure-commandline": "^2.38.1",
    "appium": "^3.2.2",
    "appium-uiautomator2-driver": "^7.1.0",
    "chai": "^6.2.2",
    "cross-env": "^7.0.3",
    "expect-webdriverio": "^5.6.5",
    "multiple-cucumber-html-reporter": "^3.8.0",
    "playwright": "^1.59.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3",
    "wdio-cucumberjs-json-reporter": "^6.0.1",
    "webdriverio": "^9.27.0"
  }
}
